import streamlit as st
import csv
import requests

# ========= CONFIG =========
OLLAMA_URL = "http://localhost:11434/api/generate"
MODELO = "tinyllama"  # pode manter esse

# ========= PROMPT =========
SYSTEM_PROMPT = """
Você é um analista de backoffice de fundos de investimento.

Seu papel é identificar possíveis ERROS operacionais na rentabilidade.

Você NÃO pode:
- Responder sobre outro assunto 
- Responder sobre notícias
- Sugerir investimentos
- Falar sobre qualquer assunto fora de fundos analise e validação de rentabilidade

Se a pergunta NÃO for sobre análise de rentabilidade:

Responda EXATAMENTE:
"Pergunta fora do escopo da análise de fundos."

Regras da análise:

- Identifique valores fora da média (outliers)
- Compare com o IBOV
- Se estiver muito fora e não acompanhar o mercado, é possível erro operacional

Formato da resposta:

Se houver erro:
FORA DA BANDA: data -> rentabilidade (possível erro operacional)

Se não houver:
TODOS OS DIAS DENTRO DO PADRÃO OPERACIONAL
"""

# ========= CARREGAR DADOS =========
def carregar_dados():
    dados = []
    with open("dados.csv", newline="", encoding="utf-8") as arquivo:
        leitor = csv.DictReader(arquivo)
        for linha in leitor:
            data = linha["data"]
            rent = float(linha["rentabilidade"])
            ibov = float(linha["IBOV"])
            dados.append((data, rent, ibov))
    return dados

# ========= ANALISE =========
def analisar_dados(dados):
    rents = [r for _, r, _ in dados]

    media = sum(rents) / len(rents)
    desvio = (sum((x - media) ** 2 for x in rents) / len(rents)) ** 0.5

    ruido = desvio * 2  # tolerância melhor
    limite_inferior = media - ruido
    limite_superior = media + ruido

    fora = []
    divergencias = []

    for data, rent, ibov in dados:
        # fora da banda
        if rent < limite_inferior or rent > limite_superior:
            fora.append((data, rent))

        # divergência com IBOV
        if (rent > 0 and ibov < 0) or (rent < 0 and ibov > 0):
            divergencias.append((data, rent, ibov))

    return media, limite_inferior, limite_superior, fora, divergencias

# ========= OLLAMA =========
def perguntar(contexto, pergunta):
    prompt = f"""
{SYSTEM_PROMPT}

DADOS:
{contexto}

Pergunta: {pergunta}
"""

    try:
        response = requests.post(
            OLLAMA_URL,
            json={"model": MODELO, "prompt": prompt, "stream": False}
        )

        data = response.json()

        if "response" in data:
            return data["response"]
        else:
            return "Erro ao consultar IA. Verifique se o Ollama está rodando."

    except:
        return "Erro de conexão com a IA."

# ========= INTERFACE =========
st.title("📊 Shay sua Analista Inteligente ")
st.write("Análise operacional de fundos (Backoffice)")

# carregar dados
dados = carregar_dados()

# analisar dados
media, li, ls, fora, divergencias = analisar_dados(dados)

# resumo
st.subheader("Resumo da Análise")
st.write(f"Média: {media:.2f}%")
st.write(f"Banda: {li:.2f}% até {ls:.2f}%")

# resultado automático
st.subheader("Validação Operacional")

if fora:
    for data, rent in fora:
        st.error(f"FORA DA BANDA: {data} -> {rent}%")
else:
    st.success("Todos os dias dentro da banda")

# divergência IBOV
if divergencias:
    st.subheader("Divergência vs IBOV")
    for data, rent, ibov in divergencias:
        st.warning(f"{data} -> Fundo: {rent}% | IBOV: {ibov}%")

# contexto IA
contexto = ""
for data, rent, ibov in dados:
    contexto += f"{data} - Fundo: {rent}% | IBOV: {ibov}%\n"

# chat
st.subheader("Chat com IA")

pergunta_user = st.chat_input("Pergunte sobre a análise...")

if pergunta_user:
    st.chat_message("user").write(pergunta_user)

    resposta = perguntar(contexto, pergunta_user)

    st.chat_message("assistant").write(resposta)
